# Database Configuration
# PostgreSQL connection string for Neon or other PostgreSQL providers
# Format: postgresql://[user]:[password]@[host]/[database]?sslmode=require
DATABASE_URL=postgresql://user:password@host/database?sslmode=require

# Authentication Configuration
# NextAuth.js configuration
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-random-secret-here-generate-with-openssl-rand-base64-32

# Vercel PR/preview deployment proxy (NextAuth v5)
# Set on BOTH Production and Preview environments in Vercel:
# This routes OAuth callbacks through the stable production domain so that
# Google's allowed redirect URIs don't need to include every preview URL.
# When a preview deployment's callback hits cawpile.org, NextAuth reads the
# preview URL from the OAuth state and redirects there to complete the flow.
# Production also needs this set so NextAuth knows to perform that redirect;
# production logins are unaffected because their state.origin matches the
# production host and no redirect occurs.
# AUTH_REDIRECT_PROXY_URL=https://cawpile.org/api/auth

# Google OAuth Configuration
# Create OAuth 2.0 credentials at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# External APIs
# Google Books API key from https://console.cloud.google.com/apis/library
GOOGLE_BOOKS_API_KEY=your-google-books-api-key

# Render Server Configuration
# URL for the video render server (used for Monthly Recap video generation)
# Falls back to http://localhost:3001 for local development when not set
NEXT_PUBLIC_RENDER_SERVER_URL=https://render.cawpile.org

# AWS S3 Configuration
# For profile picture uploads to S3
# Create IAM user with S3 access at https://console.aws.amazon.com/iam/
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_REGION=us-east-1
AWS_S3_BUCKET=cawpile-avatars

# Optional: Search Result Signing
# HMAC key for signing search results (minimum 32 characters)
# Generate with: openssl rand -base64 32
SEARCH_SIGNING_SECRET=your-search-signing-secret-minimum-32-chars

# Optional: Admin Configuration
# Email addresses that should automatically have admin privileges (comma-separated)
ADMIN_EMAILS=admin@example.com

# Optional: Development Settings
# Set to true to enable debug logging
DEBUG=false
