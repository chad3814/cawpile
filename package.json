{
  "name": "cawpile",
  "version": "0.1.1",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "prisma generate && next build --turbopack",
    "start": "next start",
    "type-check": "tsc --noEmit && npm run type-check --prefix services/video-gen",
    "lint": "eslint && npm run lint --prefix services/video-gen",
    "test": "jest && npm run test:run --prefix services/video-gen",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "postinstall": "prisma generate",
    "make-admin": "tsx scripts/fix-admin-user.ts",
    "configure-s3-cors": "tsx scripts/configure-s3-cors.ts"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.10.0",
    "@aws-sdk/client-s3": "^3.987.0",
    "@aws-sdk/s3-request-presigner": "^3.987.0",
    "@headlessui/react": "^2.2.7",
    "@heroicons/react": "^2.2.0",
    "@neondatabase/serverless": "^1.0.1",
    "@prisma/client": "^6.15.0",
    "dotenv": "^17.2.2",
    "html2canvas": "^1.4.1",
    "jszip": "^3.10.1",
    "nanoid": "^5.1.6",
    "next": "^16.2.3",
    "next-auth": "^5.0.0-beta.29",
    "prisma": "^6.15.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "recharts": "3.2.0",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/jszip": "^3.4.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/sharp": "^0.31.1",
    "eslint": "^9",
    "eslint-config-next": "15.5.2",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "tailwindcss": "^4",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "tsx": "^4.20.5",
    "typescript": "^5"
  }
}
