{
  "name": "cawpile-monorepo",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*",
    "services/*"
  ],
  "scripts": {
    "dev": "npm run dev -w apps/web",
    "dev:web": "npm run dev -w apps/web",
    "dev:mobile": "npm run dev -w apps/mobile",
    "build": "npm run build -w apps/web",
    "build:web": "npm run build -w apps/web",
    "build:shared": "npm run build -w packages/shared",
    "test": "npm run test -w apps/web",
    "test:web": "npm run test -w apps/web",
    "test:shared": "npm run test -w packages/shared",
    "test:video-gen": "npm run test:run -w services/video-gen",
    "lint": "npm run lint -w apps/web",
    "lint:web": "npm run lint -w apps/web"
  }
}
