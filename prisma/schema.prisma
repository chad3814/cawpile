generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// User model for authentication
model User {
  id            String           @id @default(cuid())
  email         String           @unique
  emailVerified DateTime?
  name          String?
  username      String?          @unique
  bio           String?
  readingGoal   Int              @default(12)
  image         String?
  isAdmin       Boolean          @default(false)
  isSuperAdmin  Boolean          @default(false)
  accounts      Account[]
  sessions      Session[]
  userBooks     UserBook[]
  adminActions  AdminAuditLog[]  @relation("AdminUser")
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
}

// NextAuth Account model
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

// NextAuth Session model
model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Book models for tracking reading
model Book {
  id        String    @id @default(cuid())
  title     String
  authors   String[]
  language  String    @default("en")
  bookType  BookType  @default(FICTION)
  editions  Edition[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@unique([title, authors])
  @@index([title])
}

model Edition {
  id            String      @id @default(cuid())
  bookId        String
  isbn10        String?
  isbn13        String?
  title         String?     // Edition-specific title if different
  authors       String[]    // Edition-specific authors if different
  format        BookFormat?
  googleBooksId String?     @unique
  book          Book        @relation(fields: [bookId], references: [id])
  userBooks     UserBook[]
  googleBook    GoogleBook?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@unique([isbn10])
  @@unique([isbn13])
  @@index([bookId])
}

model GoogleBook {
  id             String   @id @default(cuid())
  googleId       String   @unique
  editionId      String   @unique
  title          String
  subtitle       String?
  authors        String[]
  description    String?
  publishedDate  String?
  pageCount      Int?
  imageUrl       String?
  categories     String[]
  edition        Edition  @relation(fields: [editionId], references: [id])
  createdAt      DateTime @default(now())
}

model UserBook {
  id             String           @id @default(cuid())
  userId         String
  editionId      String
  status         BookStatus
  format         BookFormat
  startDate      DateTime?
  finishDate     DateTime?
  progress       Float            @default(0) // Percentage 0-100
  currentPage    Int              @default(0)
  review         String?          @db.Text
  notes          String?          @db.Text
  isFavorite     Boolean          @default(false)
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  edition        Edition          @relation(fields: [editionId], references: [id])
  cawpileRating  CawpileRating?
  readingSessions ReadingSession[]
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@unique([userId, editionId])
  @@index([userId, status])
  @@index([userId, createdAt])
}

model CawpileRating {
  id         String   @id @default(cuid())
  userBookId String   @unique
  characters Int?     // 1-10 scale, nullable for skipped
  atmosphere Int?     // 1-10 scale, nullable for skipped
  writing    Int?     // 1-10 scale, nullable for skipped
  plot       Int?     // 1-10 scale, nullable for skipped
  intrigue   Int?     // 1-10 scale, nullable for skipped
  logic      Int?     // 1-10 scale, nullable for skipped
  enjoyment  Int?     // 1-10 scale, nullable for skipped
  average    Float    // Computed average (required)
  userBook   UserBook @relation(fields: [userBookId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([userBookId])
  @@index([average])
}

model ReadingSession {
  id           String   @id @default(cuid())
  userBookId   String
  startPage    Int
  endPage      Int
  pagesRead    Int      // Computed: endPage - startPage + 1
  duration     Int?     // Duration in minutes
  notes        String?  @db.Text
  sessionDate  DateTime @default(now())
  userBook     UserBook @relation(fields: [userBookId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())

  @@index([userBookId])
  @@index([sessionDate])
}

enum BookStatus {
  WANT_TO_READ
  READING
  COMPLETED
  DNF // Did Not Finish
}

enum BookFormat {
  HARDCOVER
  PAPERBACK
  EBOOK
  AUDIOBOOK
}

enum BookType {
  FICTION
  NONFICTION
}

// Admin audit log for tracking all admin actions
model AdminAuditLog {
  id         String   @id @default(cuid())
  adminId    String
  admin      User     @relation("AdminUser", fields: [adminId], references: [id])
  entityType String   // e.g., "Book", "Edition", "User"
  entityId   String   // ID of the entity being modified
  fieldName  String?  // Column/field that was changed
  oldValue   String?  @db.Text // Previous value (JSON stringified)
  newValue   String?  @db.Text // New value (JSON stringified)
  actionType String   // CREATE, UPDATE, DELETE, MERGE
  timestamp  DateTime @default(now())

  @@index([adminId])
  @@index([entityType, entityId])
  @@index([timestamp])
}